POSTGRES_USER=hackorum
POSTGRES_PASSWORD=hackorum
POSTGRES_DB=hackorum_development

DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
PGUSER=${POSTGRES_USER}
PGPASSWORD=${POSTGRES_PASSWORD}
PGHOST=db
PGPORT=5432
PGDATABASE=${POSTGRES_DB}
SECRET_KEY_BASE=dev-secret-change-me

PORT=3000

# Optional IMAP (used when running the imap_worker profile)
IMAP_USERNAME=your-imap-username
IMAP_PASSWORD=your-imap-password
IMAP_MAILBOX_LABEL=INBOX
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SSL=true

# Email sending (Gmail API)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
HACKORUM_DEV_REPLY_TO=
HACKORUM_OUTGOING_DOMAIN=hackorum.local

# Active Record encryption keys (32+ char base64 strings)
# Generate with: bin/rails runner 'puts SecureRandom.alphanumeric(32)'
RAILS_AR_ENCRYPTION_PRIMARY_KEY=
RAILS_AR_ENCRYPTION_DETERMINISTIC_KEY=
RAILS_AR_ENCRYPTION_SALT=
