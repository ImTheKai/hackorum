RAILS_ENV=production
RAILS_LOG_TO_STDOUT=1
RAILS_SERVE_STATIC_FILES=1

# Secrets
SECRET_KEY_BASE=change-me

# Rails master key — decrypts config/credentials.yml.enc, which holds the
# Active Record encryption keys used to encrypt Identity#refresh_token and
# Identity#access_token (Gmail OAuth tokens for the "send email" feature).
#
# Set up once on the deploy host:
#   1) bin/rails db:encryption:init           # prints three keys
#   2) EDITOR=vi bin/rails credentials:edit   # paste them under active_record_encryption:
#   3) Copy the printed master key into RAILS_MASTER_KEY below
#   4) DO NOT commit config/master.key and DO NOT bake it into the image — it
#      is listed in .gitignore and .dockerignore. The key only lives here.
#
# Rotating: re-run step 1, add the new keys ABOVE the old ones in credentials,
# leaving the previous values present so existing rows stay decryptable.
RAILS_MASTER_KEY=change-me

# Optional ENV override for Active Record encryption keys. If all three are set,
# production.rb uses them instead of credentials — handy for smoke-test boots
# (e.g. prod-boot CI) where a master key is not available. Leave unset in real
# deployments so credentials remain the single source of truth.
# RAILS_AR_ENCRYPTION_PRIMARY_KEY=
# RAILS_AR_ENCRYPTION_DETERMINISTIC_KEY=
# RAILS_AR_ENCRYPTION_SALT=

# Database (used by DATABASE_URL below)
POSTGRES_USER=hackorum
POSTGRES_PASSWORD=hackorum
POSTGRES_DB=hackorum
# Keep it in sync with the above parameters!
DATABASE_URL=postgresql://hackorum:hackorum@db:5432/hackorum
HACKORUM_DATABASE_PASSWORD=hackorum

# IMAP ingestion
IMAP_USERNAME=you@example.com
IMAP_PASSWORD=app-password
IMAP_MAILBOX_LABEL=hackers-list
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SSL=true

# Gmail OAuth — used for Google sign-in AND for the per-user "send email"
# feature (separate consent flow with offline access + gmail.send scope).
#
# In Google Cloud Console for this OAuth client:
#   - Authorized redirect URI: must match GOOGLE_REDIRECT_URI exactly.
#   - Scopes: enable "https://www.googleapis.com/auth/gmail.send" in addition
#     to the default email/profile scopes.
#   - Publishing status: "In production" (verified). While the app is in
#     "Testing" mode, refresh tokens issued for gmail.send expire after 7 days,
#     after which users must re-authorize and queued sends will fail with
#     Gmail::AuthRevokedError.
GOOGLE_CLIENT_ID=change-me.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=change-me
GOOGLE_REDIRECT_URI=https://hackorum.example.com/auth/google_oauth2/callback

# Hostname for Caddy (update deploy/Caddyfile too)
APP_HOST=hackorum.example.com

# Umami analytics (self-hosted)
# Generate secrets with: openssl rand -hex 32
UMAMI_DB=umami
UMAMI_DB_USER=umami
UMAMI_DB_PASSWORD=change-me
UMAMI_DATABASE_URL=postgresql://umami:change-me@db:5432/umami
UMAMI_APP_SECRET=change-me
UMAMI_HASH_SALT=change-me
UMAMI_WEBSITE_ID=
# Optional override; defaults to https://umami.hackorum.dev
# UMAMI_HOST=https://umami.hackorum.dev

# Mail configuration via Mailgun — used for transactional mail sent BY the app
# (password reset, email verification, admin notifications). User-to-thread
# replies go out through each user's own Gmail account via the Gmail API and
# do NOT use these SMTP settings.
# Sign up at https://mailgun.com and verify your domain (use subdomain mg.example.com)
# Get credentials from Mailgun dashboard → Sending → Domain settings → SMTP credentials
MAIL_DOMAIN=mg.example.com
MAIL_FROM=noreply@mg.example.com

# Mailgun SMTP settings
# EU region (GDPR compliant): smtp.eu.mailgun.org
# US region: smtp.mailgun.org
SMTP_ADDRESS=smtp.eu.mailgun.org
SMTP_PORT=587
SMTP_DOMAIN=hackorum.dev
SMTP_USERNAME=usernamee@hackorum.dev
SMTP_PASSWORD=your-mailgun-smtp-password
